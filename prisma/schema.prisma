generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               Int        @id @default(autoincrement())
  fullName         String
  username         String     @unique
  email            String     @unique
  password         String
  role             Role
  securityQuestion String
  securityAnswer   String
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt
  lastActiveAt     DateTime?
  AuditLog         AuditLog[]
  Staff            Staff?
}

model Patient {
  id                    Int                    @id @default(autoincrement())
  patientNumber         String                 @unique
  firstName             String
  lastName              String
  gender                Gender
  age                   Int
  dateOfBirth           DateTime?
  phoneNumber           String?
  address               String?
  isEmergency           Boolean                @default(false)
  currentStatus         PatientStatus          @default(AWAITING_TRIAGE)
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  sentToTreatmentRoom   Boolean                @default(false)
  ANCAssessment         ANCAssessment[]
  Appointment           Appointment[]
  Billing               Billing[]
  CriticalNotifications CriticalNotification[]
  DentalImage           DentalImage[]
  DentalProcedure       DentalProcedure[]
  DentalRecord          DentalRecord[]
  ImagingRequest        ImagingRequest[]
  LabCommunications     LabCommunication[]
	  LabRequest            LabRequest[]
	  MedicalProcedure      MedicalProcedure[]
	  Notification          Notification[]
  OdontogramFinding     OdontogramFinding[]
  PatientReview         PatientReview[]
  PatientTimeline       PatientTimeline[]
  Prescription          Prescription[]
  ResultShares          ResultShare[]
  Triage                Triage[]
  Visit                 Visit[]
}

model Visit {
  id                      Int               @id @default(autoincrement())
  patientId               Int
  symptoms                String?
  diagnosis               String?
  notes                   String?
  createdAt               DateTime          @default(now())
  updatedAt               DateTime          @updatedAt
  assessment              String?
  differentialDiagnosis   String?
  historyOfPresentIllness String?
  pastMedicalHistory      String?
  physicalExamination     String?
  treatmentPlan           String?
  doctorSignature         String?
  reviewOfOtherSystems    String?
  doctorId                Int?
  doctorName              String?
  ANCAssessment           ANCAssessment[]
  Billing                 Billing[]
  DentalProcedure         DentalProcedure[]
  DentalRecord            DentalRecord[]
  ImagingRequest          ImagingRequest[]
  LabRequest              LabRequest[]
  Prescription            Prescription[]
  Triage                  Triage[]
  Patient                 Patient           @relation(fields: [patientId], references: [id], onDelete: Cascade)
}

model Triage {
  id                  Int      @id @default(autoincrement())
  patientId           Int
  visitId             Int?
  modeOfArrival       String?
  temperature         Float?
  bpSystolic          Int?
  bpDiastolic         Int?
  heartRate           Int?
  respiratoryRate     Int?
  spo2                Int?
  weight              Float?
  height              Float?
  painLevel           Int?
  painLocation        String?
  chiefComplaint      String?
  allergies           String?
  medicalHistory      String?
  nursingObservations String?
  nursingNotes        String?
  esiLevel            Int?
  redFlags            String?
  triageOutcome       String?
  referredTo          String?
  status              String   @default("COMPLETED")
  completedBy         Int?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  Patient             Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  Visit               Visit?   @relation(fields: [visitId], references: [id])
}

model ImagingRequest {
  id               Int       @id @default(autoincrement())
  patientId        Int
  visitId          Int?
  requestedById    Int?
  studyType        String
  priority         String    @default("ROUTINE")
  referralSource   String?
  clinicalNotes    String?
  clinicalHistory  String?
  status           String    @default("ORDERED")
  isCritical       Boolean   @default(false)
  criticalNote     String?
  imageCount       Int       @default(0)
  dicomStudyUid    String?
  findings         String?
  impression       String?
  conclusion       String?
  radiologistNotes String?
  reportedById     Int?
  reportedAt       DateTime?
  measurements     String?
  annotations      String?
  machineResults   String?
  machineModel     String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  Patient          Patient   @relation(fields: [patientId], references: [id], onDelete: Cascade)
  Staff            Staff?    @relation(fields: [requestedById], references: [id])
  Visit            Visit?    @relation(fields: [visitId], references: [id])
}

model DentalRecord {
  id                      Int                 @id @default(autoincrement())
  patientId               Int
  visitId                 Int?
  chiefComplaint          String?
  diagnosis               String?
  notes                   String?
  createdAt               DateTime            @default(now())
  updatedAt               DateTime            @updatedAt
  allergies               String?
  bpDiastolic             Int?
  bpSystolic              Int?
  clinicalExamination     String?
  extraoralExam           String?
  followUpInstructions    String?
  heartRate               Int?
  historyOfPresentIllness String?
  icdCodes                String?
  intraoralExam           String?
  medicalHistory          String?
  oralHygieneAssessment   String?
  pastDentalHistory       String?
  periodontalFindings     String?
  prescribedMedications   String?
  proceduresPerformed     String?
  reportNumber            String?
  respiratoryRate         Int?
  reviewAppointment       DateTime?
  reviewNotes             String?
  spo2                    Int?
  staffId                 Int?
  status                  String              @default("COMPLETED")
  temperature             Float?
  treatmentPlan           String?
  weight                  Float?
  DentalImage             DentalImage[]
  DentalProcedure         DentalProcedure[]
  Patient                 Patient             @relation(fields: [patientId], references: [id], onDelete: Cascade)
  Staff                   Staff?              @relation(fields: [staffId], references: [id])
  Visit                   Visit?              @relation(fields: [visitId], references: [id])
  OdontogramFinding       OdontogramFinding[]
}

model OdontogramFinding {
  id                      Int          @id @default(autoincrement())
  dentalRecordId          Int
  patientId               Int
  toothNumber             Int
  quadrant                Int
  toothType               String
  isPresent               Boolean      @default(true)
  isMissing               Boolean      @default(false)
  isExtracted             Boolean      @default(false)
  isImpacted              Boolean      @default(false)
  isUnerupted             Boolean      @default(false)
  cariesMesial            Boolean      @default(false)
  cariesDistal            Boolean      @default(false)
  cariesBuccal            Boolean      @default(false)
  cariesLingual           Boolean      @default(false)
  cariesOcclusal          Boolean      @default(false)
  cariesCervical          Boolean      @default(false)
  cariesExtensive         Boolean      @default(false)
  restorationMesial       Boolean      @default(false)
  restorationDistal       Boolean      @default(false)
  restorationBuccal       Boolean      @default(false)
  restorationLingual      Boolean      @default(false)
  restorationOcclusal     Boolean      @default(false)
  restorationType         String?
  restorationMaterial     String?
  hasCrown                Boolean      @default(false)
  crownType               String?
  isBridgeAbutment        Boolean      @default(false)
  bridgePONTIC            Boolean      @default(false)
  bridgeConnectedTo       Int?
  hasImplant              Boolean      @default(false)
  implantType             String?
  implantDate             DateTime?
  hasRootCanal            Boolean      @default(false)
  rootCanalCompleted      Boolean      @default(false)
  rootCanalTreated        Boolean      @default(false)
  postAndCore             Boolean      @default(false)
  periapicalPathology     Boolean      @default(false)
  hasFracture             Boolean      @default(false)
  fractureType            String?
  isTraumatized           Boolean      @default(false)
  hasMobility             Boolean      @default(false)
  mobilityGrade           Int?
  hasAvulsion             Boolean      @default(false)
  probingDepthMesial      Float?
  probingDepthDistal      Float?
  probingDepthBuccal      Float?
  probingDepthLingual     Float?
  bleedingOnProbing       Boolean      @default(false)
  gingivalRecession       Float?
  furcationInvolvement    Boolean      @default(false)
  furcationGrade          Int?
  clinicalAttachmentLevel Float?
  isAbutmentForPartial    Boolean      @default(false)
  isAbutmentForDenture    Boolean      @default(false)
  notes                   String?
  createdAt               DateTime     @default(now())
  updatedAt               DateTime     @updatedAt
  DentalRecord            DentalRecord @relation(fields: [dentalRecordId], references: [id], onDelete: Cascade)
  Patient                 Patient      @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([dentalRecordId])
  @@index([patientId])
  @@index([toothNumber])
}

model DentalProcedure {
  id                 Int          @id @default(autoincrement())
  dentalRecordId     Int
  patientId          Int
  visitId            Int?
  procedureType      String
  procedureName      String
  toothNumbers       String?
  arch               String?
  quadrant           Int?
  diagnosis          String?
  findings           String?
  technique          String?
  materials          String?
  complications      String?
  outcome            String?
  notes              String?
  anaesthesiaType    String?
  anaesthesiaAgent   String?
  anaesthesiaDetails String?
  fee                Float?
  isCompleted        Boolean      @default(true)
  performedBy        Int?
  performedByName    String?
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt
  DentalRecord       DentalRecord @relation(fields: [dentalRecordId], references: [id], onDelete: Cascade)
  Patient            Patient      @relation(fields: [patientId], references: [id], onDelete: Cascade)
  Visit              Visit?       @relation(fields: [visitId], references: [id])
}

model DentalImage {
  id             Int          @id @default(autoincrement())
  dentalRecordId Int
  patientId      Int
  imageType      String
  imageSubType   String?
  fileName       String
  fileSize       Int?
  mimeType       String?
  imageData      Bytes
  thumbnailData  Bytes?
  imageUrl       String?
  toothNumbers   String?
  findings       String?
  isComparison   Boolean      @default(false)
  comparisonWith Int?
  sortOrder      Int          @default(0)
  uploadedBy     String?
  uploadedAt     DateTime     @default(now())
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  DentalRecord   DentalRecord @relation(fields: [dentalRecordId], references: [id], onDelete: Cascade)
  Patient        Patient      @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([dentalRecordId])
  @@index([patientId])
}

model PatientTimeline {
  id             Int      @id @default(autoincrement())
  patientId      Int
  action         String
  fromDepartment String?
  toDepartment   String?
  description    String?
  metadata       String?
  performedBy    String?
  performedById  Int?
  createdAt      DateTime @default(now())
  Patient        Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([patientId])
  @@index([createdAt])
}

model ANCAssessment {
  id                  Int       @id @default(autoincrement())
  patientId           Int
  visitId             Int?
  gestationalAgeWeeks Int?
  gravida             Int?
  para                Int?
  LMP                 DateTime?
  EDD                 DateTime?
  fundalHeight        Float?
  fetalHeartRate      Int?
  fetalPresentation   String?
  fetalMovement       String?
  bpSystolic          Int?
  bpDiastolic         Int?
  maternalWeight      Float?
  urineProtein        String?
  urineGlucose        String?
  urineNitrites       String?
  edema               String?
  edemaLocation       String?
  complaints          String?
  clinicalNotes       String?
  nextAppointmentDate DateTime?
  outcome             String?
  referredBy          String?
  referringDoctorName String?
  assessedBy          String?
  assessedById        Int?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  Patient             Patient   @relation(fields: [patientId], references: [id], onDelete: Cascade)
  Visit               Visit?    @relation(fields: [visitId], references: [id])

  @@index([patientId])
}

model PatientReview {
  id                  Int      @id @default(autoincrement())
  patientId           Int
  followUpNotes       String?
  examinationFindings String?
  diagnosis           String?
  treatmentPlan       String?
  labOrders           String?
  imagingOrders       String?
  doctorId            Int
  doctorName          String
  createdAt           DateTime @default(now())
  Patient             Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([patientId])
  @@index([createdAt])
}

model Appointment {
  id              Int               @id @default(autoincrement())
  patientId       Int
  staffId         Int?
  appointmentDate DateTime
  status          AppointmentStatus @default(PENDING)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  createdById     Int?
  department      String?
  notes           String?
  reason          String?
  CreatedBy       Staff?            @relation("CreatedByStaff", fields: [createdById], references: [id])
  Patient         Patient           @relation(fields: [patientId], references: [id], onDelete: Cascade)
  Staff           Staff?            @relation("StaffAppointments", fields: [staffId], references: [id])
}

model StaffAttendance {
  id         Int       @id @default(autoincrement())
  staffId    Int?
  staffName  String?
  department String?
  clockIn    DateTime
  clockOut   DateTime?
  date       DateTime  @default(now())
  notes      String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  Staff      Staff?    @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@index([staffId])
  @@index([date])
  @@index([department])
}

model LabRequest {
  id                    Int                    @id @default(autoincrement())
  patientId             Int
  visitId               Int?
  requestedById         Int
  testName              String
  results               String?
  status                LabStatus              @default(PENDING)
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  attachments           String?
  clinicalNotes         String?
  collectedByName       String?
  criticalNote          String?
  enteredByName         String?
  isCritical            Boolean                @default(false)
  priority              String                 @default("ROUTINE")
  referralNotes         String?
  referralSource        String?
  rejectionReason       String?
  resultEnteredAt       DateTime?
  specimenCollectedAt   DateTime?
  specimenId            String?                @unique
  specimenRejected      Boolean                @default(false)
  specimenType          String?
  testPanel             String?
  validatedAt           DateTime?
  validatedByName       String?
  analyzerImportStatus  String?
  analyzerImportedAt    DateTime?
  analyzerModel         String?
  analyzerResults       String?
  analyzerType          String?
  chainOfCustody        String?
  processingStartedAt   DateTime?
  processingStartedBy   String?
  rejectedAt            DateTime?
  rejectedBy            String?
  rejectionCategory     String?
  CriticalNotifications CriticalNotification[]
  LabCommunications     LabCommunication[]
  Patient               Patient                @relation(fields: [patientId], references: [id], onDelete: Cascade)
  Staff                 Staff                  @relation(fields: [requestedById], references: [id])
  Visit                 Visit?                 @relation(fields: [visitId], references: [id])
  ResultShares          ResultShare[]
}

model CriticalNotification {
  id                 Int        @id @default(autoincrement())
  labRequestId       Int
  patientId          Int
  notifiedPerson     String
  notifiedDept       String
  notificationMethod String
  notifiedAt         DateTime
  acknowledgedAt     DateTime?
  acknowledgedBy     String?
  notes              String?
  createdAt          DateTime   @default(now())
  LabRequest         LabRequest @relation(fields: [labRequestId], references: [id], onDelete: Cascade)
  Patient            Patient    @relation(fields: [patientId], references: [id], onDelete: Cascade)
}

model LabCommunication {
  id            Int         @id @default(autoincrement())
  labRequestId  Int?
  patientId     Int?
  messageType   String
  message       String
  senderId      Int
  senderName    String
  senderDept    String
  recipientId   Int?
  recipientDept String?
  isRead        Boolean     @default(false)
  readAt        DateTime?
  parentId      Int?
  createdAt     DateTime    @default(now())
  LabRequest    LabRequest? @relation(fields: [labRequestId], references: [id])
  Patient       Patient?    @relation(fields: [patientId], references: [id])
  Staff         Staff       @relation(fields: [senderId], references: [id])
}

model Notification {
  id            Int       @id @default(autoincrement())
  userId        Int?
  department    String?
  title         String
  message       String
  type          String
  referenceId   Int?
  referenceType String?
  isRead        Boolean   @default(false)
  readAt        DateTime?
  createdAt     DateTime  @default(now())
  patientId     Int?
  Patient       Patient?  @relation(fields: [patientId], references: [id])
}

model ResultShare {
  id            Int        @id @default(autoincrement())
  labRequestId  Int
  patientId     Int
  sharedById    Int?
  sharedByName  String
  targetUserId  Int?
  targetDept    String
  includeReport Boolean    @default(true)
  note          String?
  sharedAt      DateTime   @default(now())
  viewedAt      DateTime?
  LabRequest    LabRequest @relation(fields: [labRequestId], references: [id], onDelete: Cascade)
  Patient       Patient    @relation(fields: [patientId], references: [id], onDelete: Cascade)
  Staff         Staff?     @relation(fields: [sharedById], references: [id])
}

model Prescription {
  id           Int                @id @default(autoincrement())
  patientId    Int
  visitId      Int?
  medication   String
  dosage       String
  instructions String
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  status       PrescriptionStatus @default(PENDING)
  Patient      Patient            @relation(fields: [patientId], references: [id], onDelete: Cascade)
  Visit        Visit?             @relation(fields: [visitId], references: [id])
}

model Billing {
  id          Int           @id @default(autoincrement())
  patientId   Int
  visitId     Int?
  amount      Float
  description String?
  status      BillingStatus @default(UNPAID)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  Patient     Patient       @relation(fields: [patientId], references: [id], onDelete: Cascade)
  Visit       Visit?        @relation(fields: [visitId], references: [id])
}

model Staff {
  id                  Int                @id @default(autoincrement())
  fullName            String
  phoneNumber         String?
  department          String
  specialization      String?
  userId              Int                @unique
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
  AppointmentsCreated Appointment[]      @relation("CreatedByStaff")
  Appointment         Appointment[]      @relation("StaffAppointments")
  DentalRecord        DentalRecord[]
  ImagingRequest      ImagingRequest[]
  LabCommunications   LabCommunication[]
  LabRequest          LabRequest[]
  ResultShares        ResultShare[]
  User                User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  StaffAttendance     StaffAttendance[]
}

model AuditLog {
  id        Int      @id @default(autoincrement())
  action    String
  details   String?
  userId    Int
  createdAt DateTime @default(now())
  User      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model StaffMessage {
  id         Int      @id @default(autoincrement())
  senderName String
  senderDept String
  message    String
  targetDept String?
  createdAt  DateTime @default(now())
}

model MedicalProcedure {
  id                Int      @id @default(autoincrement())
  patientId         Int
  procedureName     String
  procedureNotes    String
  treatmentFollowUp String?
  performedBy       String
  createdAt         DateTime @default(now())
  Patient           Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
}

enum PatientStatus {
  REGISTERED
  AWAITING_TRIAGE
  AWAITING_SONOGRAPHY
  AWAITING_RADIOLOGY
  AWAITING_LAB
  IN_CONSULTATION
  AWAITING_PHARMACY
  AWAITING_CASHIER
  DISCHARGED
  AWAITING_DOCTOR
  AWAITING_DENTIST
  ADMITTED
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELLED
}

enum BillingStatus {
  UNPAID
  PAID
  PARTIAL
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum LabStatus {
  PENDING
  PROCESSING
  COMPLETED
  SPECIMEN_COLLECTED
  AWAITING_VALIDATION
  REJECTED
}

enum PrescriptionStatus {
  PENDING
  DISPENSED
}

enum Role {
  ADMINISTRATOR
  DOCTOR
  NURSE
  MIDWIFE
  LAB_TECHNICIAN
  SONOGRAPHER
  RADIOLOGIST
  RECEPTIONIST
  CASHIER
  PHARMACIST
  DENTIST
  NURSE_MIDWIFE
  RADIOLOGIST_SONOGRAPHER
}
