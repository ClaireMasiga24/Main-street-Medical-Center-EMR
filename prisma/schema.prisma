generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               Int        @id @default(autoincrement())
  fullName         String
  username         String     @unique
  email            String     @unique
  password         String
  role             Role
  securityQuestion String
  securityAnswer   String
  lastActiveAt     DateTime?
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt
  AuditLog         AuditLog[]
  Staff            Staff?
}

model Patient {
  id            Int       @id @default(autoincrement())
  patientNumber String    @unique // This matches the generated Care ID (e.g., MSMC-2026-X)
  firstName     String
  lastName      String
  gender        Gender
  age           Int // Stored directly to accommodate emergency estimates
  dateOfBirth   DateTime? // Optional (!) so Emergency entries can bypass it
  phoneNumber   String?
  address       String?
  isEmergency   Boolean   @default(false)

  // The operational status engine that shares the patient across rooms
  currentStatus PatientStatus @default(AWAITING_TRIAGE)

  // Flag: ADMITTED patient sent to the nurse/midwife Treatment Room
  // Status stays ADMITTED so the doctor still sees them in Admitted Patients
  sentToTreatmentRoom Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  Appointment  Appointment[]
  Billing      Billing[]
  LabRequest   LabRequest[]
  Prescription Prescription[]
  Visit        Visit[]
  DentalRecord DentalRecord[]
  Triage       Triage[]
  ImagingRequest ImagingRequest[]
  CriticalNotifications CriticalNotification[]
  LabCommunications     LabCommunication[]
  Notification          Notification[]
  ResultShares          ResultShare[]
  OdontogramFinding OdontogramFinding[]
  DentalProcedure   DentalProcedure[]
  DentalImage       DentalImage[]
	  PatientTimeline   PatientTimeline[]
	  PatientReview    PatientReview[]
	  ANCAssessment     ANCAssessment[]
	}

model Visit {
  id        Int      @id @default(autoincrement())
  patientId Int

  // ── Chief Complaint & History ──────────────────────────────────────
  symptoms              String?  @db.Text  // Also serves as Chief Complaint / Reason for visit
  historyOfPresentIllness String? @db.Text
  pastMedicalHistory    String?  @db.Text  // Combined past medical & surgical history
  reviewOfOtherSystems  String?  @db.Text

  // ── Examination & Diagnosis ────────────────────────────────────────
  physicalExamination   String?  @db.Text
  diagnosis             String?  @db.Text
  differentialDiagnosis String?  @db.Text
  assessment            String?  @db.Text
  treatmentPlan         String?  @db.Text

  // ── Clinical Notes ─────────────────────────────────────────────────
  notes     String?  @db.Text
  doctorSignature String? @db.Text
  doctorId  Int?
  doctorName String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  Patient   Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)

  // Unified connections: Helps associate actions with this specific hospital stay
  LabRequest   LabRequest[]
  Prescription Prescription[]
  Billing      Billing[]
  DentalRecord DentalRecord[]
  DentalProcedure DentalProcedure[]
	  Triage       Triage[]
	  ImagingRequest ImagingRequest[]
	  ANCAssessment ANCAssessment[]
	}

model Triage {
  id                    Int      @id @default(autoincrement())
  patientId             Int
  visitId               Int?

  // ── Arrival ───────────────────────────────────────────────────────
  modeOfArrival         String?  // WALK_IN | AMBULANCE | WHEELCHAIR | REFERRAL | TRANSFER

  // ── Vital Signs ───────────────────────────────────────────────────
  temperature           Float?   // Celsius
  bpSystolic            Int?     // mmHg
  bpDiastolic           Int?     // mmHg
  heartRate             Int?     // bpm (pulse rate)
  respiratoryRate       Int?     // breaths/min
  spo2                  Int?     // % SpO₂
  weight                Float?   // kg
  height                Float?   // cm

  // ── Pain Assessment ───────────────────────────────────────────────
  painLevel             Int?     // 0–10
  painLocation          String?

  // ── Clinical Assessment ───────────────────────────────────────────
  chiefComplaint        String?  @db.Text
  allergies             String?  @db.Text
  medicalHistory        String?  @db.Text
  nursingObservations   String?  @db.Text
  nursingNotes          String?  @db.Text

  // ── ESI & Red Flags ───────────────────────────────────────────────
  esiLevel              Int?     // 1–5 (Emergency Severity Index)
  redFlags              String?  @db.Text // JSON array — e.g. ["Airway compromise","Shock"]

  // ── Triage Outcome ────────────────────────────────────────────────
  triageOutcome         String?  // SEND_DOCTOR | EMERGENCY | OBSERVATION | SPECIALIST | DISCHARGE
  referredTo            String?  // department / specialist name if triageOutcome = SPECIALIST

  // ── Meta ──────────────────────────────────────────────────────────
  status                String   @default("COMPLETED")
  completedBy           Int?

  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  Patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)
  Visit   Visit?  @relation(fields: [visitId], references: [id])
}

model ImagingRequest {
  id             Int      @id @default(autoincrement())
  patientId      Int
  visitId        Int?
  requestedById  Int?     // Staff ID of the requesting clinician

  // ── Study Details ─────────────────────────────────────────────────
  studyType      String   // X_RAY | ULTRASOUND | CT_SCAN | MRI | MAMMOGRAPHY | ECHOCARDIOGRAPHY | DOPPLER | FLUOROSCOPY
  priority       String   @default("ROUTINE") // ROUTINE | URGENT | STAT
  referralSource String?  // RECEPTION | TRIAGE | DOCTOR | EMERGENCY | SPECIALIST | WARD

  // ── Clinical ──────────────────────────────────────────────────────
  clinicalNotes  String?  @db.Text  // Reason for investigation
  clinicalHistory String? @db.Text

  // ── Status Workflow ───────────────────────────────────────────────
  status         String   @default("ORDERED")
  // ORDERED → ACCEPTED → IN_PROGRESS → AWAITING_INTERPRETATION → REPORTED
  // CANCELLED at any point

  // ── Critical Findings ─────────────────────────────────────────────
  isCritical     Boolean  @default(false)
  criticalNote   String?  @db.Text

  // ── Imaging Data ──────────────────────────────────────────────────
  imageCount     Int      @default(0)
  dicomStudyUid  String?  // Placeholder for DICOM integration

  // ── Report ────────────────────────────────────────────────────────
  findings       String?  @db.Text
  impression     String?  @db.Text
  conclusion     String?  @db.Text
  radiologistNotes String? @db.Text
  reportedById   Int?
  reportedAt     DateTime?

  // ── Measurements & Annotations (JSON) ─────────────────────────────
  measurements   String?  @db.Text  // JSON — {"label":"Liver size","value":"15.2","unit":"cm"}
  annotations    String?  @db.Text  // JSON — free-form annotation data

  // ── Machine Integration ───────────────────────────────────────────
  machineResults String?  @db.Text  // Raw machine output / DICOM structured report
  machineModel   String?  // Name/model of the device used

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  Patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)
  Visit   Visit?  @relation(fields: [visitId], references: [id])
  Staff   Staff?  @relation(fields: [requestedById], references: [id])
}

model DentalRecord {
  id                    Int               @id @default(autoincrement())
  patientId             Int
  visitId               Int?
  staffId               Int?
  reportNumber          String?

  // ── Chief Complaint & History ──────────────────────────────────────────
  chiefComplaint        String?           @db.Text
  historyOfPresentIllness String?         @db.Text
  pastDentalHistory     String?           @db.Text
  medicalHistory        String?           @db.Text
  allergies             String?           @db.Text

  // ── Vital Signs ────────────────────────────────────────────────────────
  temperature           Float?
  bpSystolic            Int?
  bpDiastolic           Int?
  heartRate             Int?
  respiratoryRate       Int?
  spo2                  Int?
  weight                Float?

  // ── Clinical Examination ───────────────────────────────────────────────
  clinicalExamination   String?           @db.Text
  extraoralExam         String?           @db.Text
  intraoralExam         String?           @db.Text
  periodontalFindings   String?           @db.Text
  oralHygieneAssessment String?           @db.Text

  // ── Diagnosis & Treatment ──────────────────────────────────────────────
  diagnosis             String?           @db.Text
  icdCodes              String?           @db.Text  // JSON array
  treatmentPlan         String?           @db.Text
  proceduresPerformed   String?           @db.Text  // JSON array of procedure IDs
  prescribedMedications String?           @db.Text  // JSON array of prescriptions

  // ── Follow-Up ──────────────────────────────────────────────────────────
  followUpInstructions  String?           @db.Text
  reviewAppointment     DateTime?
  reviewNotes           String?           @db.Text

  // ── General Notes & Status ──────────────────────────────────────────────
  notes                 String?           @db.Text
  status                String            @default("COMPLETED") // COMPLETED | FOLLOW_UP | REFERRED

  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt

  Patient               Patient           @relation(fields: [patientId], references: [id], onDelete: Cascade)
  Visit                 Visit?            @relation(fields: [visitId], references: [id])
  Staff                 Staff?            @relation(fields: [staffId], references: [id])
  OdontogramFinding     OdontogramFinding[]
  DentalProcedure       DentalProcedure[]
  DentalImage           DentalImage[]
}

model OdontogramFinding {
  id               Int      @id @default(autoincrement())
  dentalRecordId   Int
  patientId        Int

  // ── Tooth Identification (Universal numbering 1-32) ─────────────────────
  toothNumber      Int      // 1-32 (ADA Universal)
  quadrant         Int      // 1=UR, 2=UL, 3=LL, 4=LR
  toothType        String   // INCISOR | CANINE | PREMOLAR | MOLAR

  // ── Tooth Status Flags ─────────────────────────────────────────────────
  isPresent        Boolean  @default(true)
  isMissing        Boolean  @default(false)
  isExtracted      Boolean  @default(false)
  isImpacted       Boolean  @default(false)
  isUnerupted      Boolean  @default(false)

  // ── Caries ─────────────────────────────────────────────────────────────
  cariesMesial     Boolean  @default(false)
  cariesDistal     Boolean  @default(false)
  cariesBuccal     Boolean  @default(false)
  cariesLingual    Boolean  @default(false)
  cariesOcclusal   Boolean  @default(false)
  cariesCervical   Boolean  @default(false)
  cariesExtensive  Boolean  @default(false) // Large/compound lesion

  // ── Restorations ───────────────────────────────────────────────────────
  restorationMesial   Boolean @default(false)
  restorationDistal   Boolean @default(false)
  restorationBuccal   Boolean @default(false)
  restorationLingual  Boolean @default(false)
  restorationOcclusal Boolean @default(false)
  restorationType     String? // AMALGAM | COMPOSITE | GLASS_IONOMER | TEMPORARY | OTHER
  restorationMaterial String?

  // ── Crown & Bridge ─────────────────────────────────────────────────────
  hasCrown          Boolean @default(false)
  crownType         String? // FULL_METAL | PFM | ALL_CERAMIC | ZIRCONIA | TEMPORARY | OTHER
  isBridgeAbutment  Boolean @default(false)
  bridgePONTIC      Boolean @default(false) // This tooth is a pontic (false tooth)
  bridgeConnectedTo Int?    // Tooth number connected to

  // ── Implant ────────────────────────────────────────────────────────────
  hasImplant        Boolean @default(false)
  implantType       String? // SINGLE | MULTI_UNIT | FULL_ARCH
  implantDate       DateTime?

  // ── Endodontics ────────────────────────────────────────────────────────
  hasRootCanal      Boolean @default(false)
  rootCanalCompleted Boolean @default(false)
  rootCanalTreated  Boolean @default(false) // Already treated in past
  postAndCore       Boolean @default(false)
  periapicalPathology Boolean @default(false)

  // ── Fracture & Trauma ─────────────────────────────────────────────────
  hasFracture       Boolean @default(false)
  fractureType      String? // CRAZE_LINE | CUSP | CRACKED_TOOTH | SPLIT_TOOTH | VERTICAL_ROOT | CROWN_FRACTURE | ROOT_FRACTURE
  isTraumatized     Boolean @default(false)
  hasMobility       Boolean @default(false)
  mobilityGrade     Int?    // 0-3
  hasAvulsion       Boolean @default(false)

  // ── Periodontal ────────────────────────────────────────────────────────
  probingDepthMesial    Float?
  probingDepthDistal    Float?
  probingDepthBuccal    Float?
  probingDepthLingual   Float?
  bleedingOnProbing     Boolean @default(false)
  gingivalRecession     Float?
  furcationInvolvement  Boolean @default(false)
  furcationGrade        Int?    // 1-3
  clinicalAttachmentLevel Float?

  // ── Abutment ──────────────────────────────────────────────────────────
  isAbutmentForPartial  Boolean @default(false)
  isAbutmentForDenture  Boolean @default(false)

  // ── Notes ──────────────────────────────────────────────────────────────
  notes             String?  @db.Text

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  DentalRecord      DentalRecord @relation(fields: [dentalRecordId], references: [id], onDelete: Cascade)
  Patient           Patient      @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([dentalRecordId])
  @@index([patientId])
  @@index([toothNumber])
}

model DentalProcedure {
  id              Int      @id @default(autoincrement())
  dentalRecordId  Int
  patientId       Int
  visitId         Int?

  // ── Procedure Details ──────────────────────────────────────────────────
  procedureType   String   // EXTRACTION | FILLING | SCALING | RCT | CROWN | BRIDGE | DENTURE | IMPLANT | PERIODONTAL | ORAL_SURGERY | PROPHYLAXIS | FLUORIDE | SEALANT | BLEACHING | VENEER | OTHER
  procedureName   String
  toothNumbers    String?  // JSON array of tooth numbers
  arch            String?  // UPPER | LOWER | BOTH
  quadrant        Int?

  // ── Clinical Details ───────────────────────────────────────────────────
  diagnosis       String?  @db.Text
  findings         String? @db.Text
  technique        String? @db.Text
  materials        String? @db.Text
  complications    String? @db.Text
  outcome          String?  // SUCCESSFUL | PARTIAL | FAILED | ABANDONED
  notes            String?  @db.Text

  // ── Anaesthesia ────────────────────────────────────────────────────────
  anaesthesiaType   String? // LOCAL | GENERAL | CONSCIOUS_SEDATION | NONE
  anaesthesiaAgent  String?
  anaesthesiaDetails String? @db.Text

  // ── Billing ────────────────────────────────────────────────────────────
  fee               Float?
  isCompleted       Boolean  @default(true)
  performedBy       Int?     // Staff ID
  performedByName   String?

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  DentalRecord      DentalRecord @relation(fields: [dentalRecordId], references: [id], onDelete: Cascade)
  Patient           Patient      @relation(fields: [patientId], references: [id], onDelete: Cascade)
  Visit             Visit?       @relation(fields: [visitId], references: [id])
}

model DentalImage {
  id              Int      @id @default(autoincrement())
  dentalRecordId  Int
  patientId       Int

  // ── Image Type ─────────────────────────────────────────────────────────
  imageType       String   // INTRAORAL | PANORAMIC | BITEWING | PERIAPICAL | CEPHALOMETRIC | CBCT | OCCLUSAL | EXTRAORAL | OTHER
  imageSubType    String?  // FRONTAL | RIGHT_LATERAL | LEFT_LATERAL | UPPER_OCCLUSAL | LOWER_OCCLUSAL | RIGHT_POSTERIOR | LEFT_POSTERIOR | OTHER

  // ── File Data ──────────────────────────────────────────────────────────
  fileName        String
  fileSize        Int?
  mimeType        String?
  imageData       Bytes   // Base64 or binary stored in DB
  thumbnailData   Bytes?  // Smaller preview
  imageUrl        String? // Fallback URL if stored externally

  // ── Metadata ───────────────────────────────────────────────────────────
  toothNumbers    String?  // JSON array — which teeth are visible
  findings        String?  @db.Text
  isComparison    Boolean  @default(false)
  comparisonWith  Int?     // ID of another DentalImage for side-by-side
  sortOrder       Int      @default(0)

  // ── Upload Info ────────────────────────────────────────────────────────
  uploadedBy      String?
  uploadedAt      DateTime @default(now())

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  DentalRecord   DentalRecord @relation(fields: [dentalRecordId], references: [id], onDelete: Cascade)
  Patient        Patient      @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([dentalRecordId])
  @@index([patientId])
}

model PatientTimeline {
  id             Int      @id @default(autoincrement())
  patientId      Int
  action         String   // ARRIVAL | TRANSFER | CONSULTATION_START | CONSULTATION_END | PROCEDURE | LAB_REQUEST | IMAGING_REQUEST | PRESCRIPTION | DISCHARGE | EMERGENCY_TAG | STATUS_CHANGE
  fromDepartment String?
  toDepartment   String?
  description    String?  @db.Text
  metadata       String?  @db.Text // JSON for additional context
  performedBy    String?
  performedById  Int?
  createdAt      DateTime @default(now())

  Patient        Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([patientId])
  @@index([createdAt])
}

model ANCAssessment {
  id                    Int      @id @default(autoincrement())
  patientId             Int
  visitId               Int?

  // ── Demographics ──────────────────────────────────────────────────
  gestationalAgeWeeks   Int?     // weeks
  gravida               Int?
  para                  Int?
  LMP                   DateTime? // Last Menstrual Period
  EDD                   DateTime? // Estimated Delivery Date (auto-calc from LMP)

  // ── Clinical Assessment ───────────────────────────────────────────
  fundalHeight          Float?   // cm
  fetalHeartRate        Int?     // bpm
  fetalPresentation     String?  // CEPHALIC | BREECH | TRANSVERSE | OBLIQUE
  fetalMovement         String?  // PRESENT | ABSENT | REDUCED

  // ── Maternal Vitals ───────────────────────────────────────────────
  bpSystolic            Int?     // mmHg
  bpDiastolic           Int?     // mmHg
  maternalWeight        Float?   // kg

  // ── Urine Dipstick ────────────────────────────────────────────────
  urineProtein          String?  // NEGATIVE | TRACE | PLUS_1 | PLUS_2 | PLUS_3
  urineGlucose          String?  // NEGATIVE | TRACE | PLUS_1 | PLUS_2 | PLUS_3
  urineNitrites         String?  // NEGATIVE | TRACE | PLUS_1 | PLUS_2 | PLUS_3

  // ── Edema ─────────────────────────────────────────────────────────
  edema                 String?  // NONE | MILD | MODERATE | SEVERE
  edemaLocation         String?

  // ── Symptoms & Notes ──────────────────────────────────────────────
  complaints            String?  @db.Text
  clinicalNotes         String?  @db.Text

  // ── Follow-Up ─────────────────────────────────────────────────────
  nextAppointmentDate   DateTime?
  outcome               String?  // CONTINUE_MONITORING | REFER_TO_DOCTOR | ADMIT | DISCHARGE

  // ── Referral Source ───────────────────────────────────────────────
  referredBy            String?  // Doctor name or "Receptionist"
  referringDoctorName   String?

  // ── Meta ──────────────────────────────────────────────────────────
  assessedBy            String?
  assessedById          Int?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  Patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)
  Visit   Visit?  @relation(fields: [visitId], references: [id])

  @@index([patientId])
}

model PatientReview {
  id              Int      @id @default(autoincrement())
  patientId       Int

  // ── Review Content ─────────────────────────────────────────────────
  followUpNotes        String? @db.Text
  examinationFindings String? @db.Text
  diagnosis           String? @db.Text
  treatmentPlan       String? @db.Text
  labOrders           String? @db.Text  // JSON array
  imagingOrders       String? @db.Text  // JSON array

  // ── Doctor Info ────────────────────────────────────────────────────
  doctorId   Int
  doctorName String

  createdAt DateTime @default(now())
  Patient   Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([patientId])
  @@index([createdAt])
}

model Appointment {
  id              Int               @id @default(autoincrement())
  patientId       Int
  staffId         Int?
  createdById     Int?
  department      String?
  appointmentDate DateTime
  reason          String?           @db.Text
  notes           String?           @db.Text
  status          AppointmentStatus @default(PENDING)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  Patient         Patient           @relation(fields: [patientId], references: [id], onDelete: Cascade)
  Staff           Staff?            @relation("StaffAppointments", fields: [staffId], references: [id])
  CreatedBy       Staff?            @relation("CreatedByStaff", fields: [createdById], references: [id])
}

model StaffAttendance {
  id             Int      @id @default(autoincrement())
  staffId        Int?
  staffName      String?
  department     String?
  clockIn        DateTime
  clockOut       DateTime?
  date           DateTime @default(now())
  notes          String?  @db.Text
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  Staff          Staff?   @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@index([staffId])
  @@index([date])
  @@index([department])
}

model LabRequest {
  id                  Int       @id @default(autoincrement())
  patientId           Int
  visitId             Int?
  requestedById       Int

  // ── Request Details ───────────────────────────────────────────────────
  testName            String
  testPanel           String?
  priority            String    @default("ROUTINE")
  referralSource      String?
  referralNotes       String?   @db.Text
  clinicalNotes       String?   @db.Text

  // ── Specimen Tracking ─────────────────────────────────────────────────
  specimenType        String?
  specimenId          String?   @unique
  specimenCollectedAt DateTime?
  collectedByName     String?
  specimenRejected    Boolean   @default(false)
  rejectedAt          DateTime?
  rejectedBy          String?
  rejectionReason     String?   @db.Text
  rejectionCategory   String?   // HEMOLYZED | CLOTTED | INSUFFICIENT | WRONG_CONTAINER | MISLABELED | CONTAMINATED | EXPIRED | TRANSPORT | PREPARATION | DUPLICATE | OTHER

  // ── Processing & TAT ─────────────────────────────────────────────────
  processingStartedAt DateTime?
  processingStartedBy String?

  // ── Results Entry ─────────────────────────────────────────────────────
  results             String?   @db.Text  // JSON array
  resultEnteredAt     DateTime?
  enteredByName       String?

  // ── Validation ────────────────────────────────────────────────────────
  validatedByName     String?
  validatedAt         DateTime?
  isCritical          Boolean   @default(false)
  criticalNote        String?   @db.Text

  // ── Analyzer Integration ──────────────────────────────────────────────
  analyzerType        String?   // CBC | CHEMISTRY | HEMATOLOGY | URINALYSIS | COAGULATION | IMMUNOLOGY | MICROBIOLOGY | OTHER
  analyzerResults     String?   @db.Text  // Raw JSON from analyzer
  analyzerModel       String?
  analyzerImportedAt  DateTime?
  analyzerImportStatus String?  // PENDING | IMPORTED | REVIEWED | REJECTED

  // ── Chain of Custody ─────────────────────────────────────────────────
  chainOfCustody      String?   @db.Text  // JSON array: [{action,by,at,from,to}]

  // ── Attachments ───────────────────────────────────────────────────────
  attachments         String?   @db.Text  // JSON array

  // ── Status ────────────────────────────────────────────────────────────
  status              LabStatus @default(PENDING)

  // ── Meta ──────────────────────────────────────────────────────────────
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  Patient             Patient   @relation(fields: [patientId], references: [id], onDelete: Cascade)
  Visit               Visit?    @relation(fields: [visitId], references: [id])
  Staff               Staff     @relation(fields: [requestedById], references: [id])

  CriticalNotifications CriticalNotification[]
  LabCommunications     LabCommunication[]
  ResultShares          ResultShare[]
}

model CriticalNotification {
  id              Int      @id @default(autoincrement())
  labRequestId    Int
  patientId       Int
  notifiedPerson  String   // Who was notified
  notifiedDept    String   // Department notified
  notificationMethod String // PHONE | PAGE | IN_PERSON | EMAIL | SYSTEM
  notifiedAt      DateTime
  acknowledgedAt  DateTime?
  acknowledgedBy  String?
  notes           String?  @db.Text
  createdAt       DateTime @default(now())

  LabRequest LabRequest @relation(fields: [labRequestId], references: [id], onDelete: Cascade)
  Patient    Patient    @relation(fields: [patientId], references: [id], onDelete: Cascade)
}

model LabCommunication {
  id              Int      @id @default(autoincrement())
  labRequestId    Int?
  patientId       Int?
  messageType     String   // COMMENT | CLARIFICATION | SPECIMEN_ISSUE | REPEAT_REQUEST | CRITICAL_ALERT | GENERAL
  message         String   @db.Text
  senderId        Int
  senderName      String
  senderDept      String
  recipientId     Int?     // Staff ID
  recipientDept   String?  // Department to receive
  isRead          Boolean  @default(false)
  readAt          DateTime?
  parentId        Int?     // For threading
  createdAt       DateTime @default(now())

  LabRequest LabRequest? @relation(fields: [labRequestId], references: [id])
  Patient    Patient?    @relation(fields: [patientId], references: [id])
  Staff      Staff       @relation(fields: [senderId], references: [id])
}

model Notification {
  id            Int      @id @default(autoincrement())
  userId        Int?
  patientId     Int?     // So the recipient can jump straight to the patient
  department    String?  // Target department
  title         String
  message       String   @db.Text
  type          String   // CRITICAL_RESULT | RESULT_READY | RESULT_SHARED | COMMUNICATION | REPEAT_REQUEST | GENERAL
  referenceId   Int?     // Optional: ID of related entity (lab request, etc.)
  referenceType String?  // lab_request | communication | etc.
  isRead        Boolean  @default(false)
  readAt        DateTime?
  createdAt     DateTime @default(now())


  Patient Patient? @relation(fields: [patientId], references: [id])
}

model ResultShare {
  id            Int      @id @default(autoincrement())
  labRequestId  Int
  patientId     Int
  sharedById    Int
  sharedByName  String
  targetUserId  Int?     // Specific user
  targetDept    String   // Target department
  includeReport Boolean  @default(true)
  note          String?  @db.Text
  sharedAt      DateTime @default(now())
  viewedAt      DateTime?

  LabRequest LabRequest @relation(fields: [labRequestId], references: [id], onDelete: Cascade)
  Patient    Patient    @relation(fields: [patientId], references: [id], onDelete: Cascade)
  Staff      Staff?     @relation(fields: [sharedById], references: [id])
}

model Prescription {
  id           Int      @id @default(autoincrement())
  patientId    Int
  visitId      Int?
  medication   String
  dosage       String
  instructions String   @db.Text
  status       PrescriptionStatus @default(PENDING)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  Patient      Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  Visit        Visit?   @relation(fields: [visitId], references: [id])
}

model Billing {
  id          Int           @id @default(autoincrement())
  patientId   Int
  visitId     Int? // Essential for calculating line-items per visit
  amount      Float
  description String?       @db.Text
  status      BillingStatus @default(UNPAID)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  Patient     Patient       @relation(fields: [patientId], references: [id], onDelete: Cascade)
  Visit       Visit?        @relation(fields: [visitId], references: [id])
}

model Staff {
  id             Int           @id @default(autoincrement())
  fullName       String
  phoneNumber    String?
  department     String
  specialization String?
  userId         Int           @unique
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  Appointment    Appointment[]          @relation("StaffAppointments")
  AppointmentsCreated Appointment[]    @relation("CreatedByStaff")
  StaffAttendance StaffAttendance[]
  LabRequest     LabRequest[]
  ImagingRequest ImagingRequest[]
  LabCommunications LabCommunication[]
  ResultShares     ResultShare[]
  DentalRecord     DentalRecord[]
  User             User          @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AuditLog {
  id        Int      @id @default(autoincrement())
  action    String
  details   String?  @db.Text
  userId    Int
  createdAt DateTime @default(now())
  User      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model StaffMessage {
  id          Int      @id @default(autoincrement())
  senderName  String
  senderDept  String
  message     String   @db.Text
  targetDept  String?  // null = all departments / facility-wide
  createdAt   DateTime @default(now())
}

// --- ENUMS ---

enum PatientStatus {
  AWAITING_TRIAGE
  AWAITING_DOCTOR
  AWAITING_DENTIST
  AWAITING_SONOGRAPHY
  AWAITING_RADIOLOGY
  AWAITING_LAB
  IN_CONSULTATION
  ADMITTED
  AWAITING_PHARMACY
  AWAITING_CASHIER
  DISCHARGED
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELLED
}

enum BillingStatus {
  UNPAID
  PAID
  PARTIAL
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum LabStatus {
  PENDING
  SPECIMEN_COLLECTED
  PROCESSING
  AWAITING_VALIDATION
  COMPLETED
  REJECTED
}
enum PrescriptionStatus {
  PENDING
  DISPENSED
}
enum Role {
  ADMINISTRATOR
  DENTIST
  DOCTOR
  NURSE
  NURSE_MIDWIFE
  MIDWIFE
  LAB_TECHNICIAN
  SONOGRAPHER
  RADIOLOGIST
  RADIOLOGIST_SONOGRAPHER
  RECEPTIONIST
  CASHIER
  PHARMACIST
}
