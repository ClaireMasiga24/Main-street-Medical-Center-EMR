generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               Int        @id @default(autoincrement())
  fullName         String
  username         String     @unique
  email            String     @unique
  password         String
  role             Role
  securityQuestion String
  securityAnswer   String
  lastActiveAt     DateTime?
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt
  AuditLog         AuditLog[]
  Staff            Staff?
}

model Patient {
  id            Int       @id @default(autoincrement())
  patientNumber String    @unique // This matches the generated Care ID (e.g., MSMC-2026-X)
  firstName     String
  lastName      String
  gender        Gender
  age           Int // Stored directly to accommodate emergency estimates
  dateOfBirth   DateTime? // Optional (!) so Emergency entries can bypass it
  phoneNumber   String?
  address       String?
  isEmergency   Boolean   @default(false)

  // The operational status engine that shares the patient across rooms
  currentStatus PatientStatus @default(AWAITING_TRIAGE)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  Appointment  Appointment[]
  Billing      Billing[]
  LabRequest   LabRequest[]
  Prescription Prescription[]
  Visit        Visit[]
  DentalRecord DentalRecord[]
  Triage       Triage[]
  ImagingRequest ImagingRequest[]
  CriticalNotifications CriticalNotification[]
  LabCommunications     LabCommunication[]
  ResultShares          ResultShare[]
}

model Visit {
  id        Int      @id @default(autoincrement())
  patientId Int
  symptoms  String?  @db.Text
  diagnosis String?  @db.Text
  notes     String?  @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  Patient   Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)

  // Unified connections: Helps associate actions with this specific hospital stay
  LabRequest   LabRequest[]
  Prescription Prescription[]
  Billing      Billing[]
  DentalRecord DentalRecord[]
  Triage       Triage[]
  ImagingRequest ImagingRequest[]
}

model Triage {
  id                    Int      @id @default(autoincrement())
  patientId             Int
  visitId               Int?

  // ── Arrival ───────────────────────────────────────────────────────
  modeOfArrival         String?  // WALK_IN | AMBULANCE | WHEELCHAIR | REFERRAL | TRANSFER

  // ── Vital Signs ───────────────────────────────────────────────────
  temperature           Float?   // Celsius
  bpSystolic            Int?     // mmHg
  bpDiastolic           Int?     // mmHg
  heartRate             Int?     // bpm (pulse rate)
  respiratoryRate       Int?     // breaths/min
  spo2                  Int?     // % SpO₂
  weight                Float?   // kg
  height                Float?   // cm

  // ── Pain Assessment ───────────────────────────────────────────────
  painLevel             Int?     // 0–10
  painLocation          String?

  // ── Clinical Assessment ───────────────────────────────────────────
  chiefComplaint        String?  @db.Text
  allergies             String?  @db.Text
  medicalHistory        String?  @db.Text
  nursingObservations   String?  @db.Text
  nursingNotes          String?  @db.Text

  // ── ESI & Red Flags ───────────────────────────────────────────────
  esiLevel              Int?     // 1–5 (Emergency Severity Index)
  redFlags              String?  @db.Text // JSON array — e.g. ["Airway compromise","Shock"]

  // ── Triage Outcome ────────────────────────────────────────────────
  triageOutcome         String?  // SEND_DOCTOR | EMERGENCY | OBSERVATION | SPECIALIST | DISCHARGE
  referredTo            String?  // department / specialist name if triageOutcome = SPECIALIST

  // ── Meta ──────────────────────────────────────────────────────────
  status                String   @default("COMPLETED")
  completedBy           Int?

  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  Patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)
  Visit   Visit?  @relation(fields: [visitId], references: [id])
}

model ImagingRequest {
  id             Int      @id @default(autoincrement())
  patientId      Int
  visitId        Int?
  requestedById  Int?     // Staff ID of the requesting clinician

  // ── Study Details ─────────────────────────────────────────────────
  studyType      String   // X_RAY | ULTRASOUND | CT_SCAN | MRI | MAMMOGRAPHY | ECHOCARDIOGRAPHY | DOPPLER | FLUOROSCOPY
  priority       String   @default("ROUTINE") // ROUTINE | URGENT | STAT
  referralSource String?  // RECEPTION | TRIAGE | DOCTOR | EMERGENCY | SPECIALIST | WARD

  // ── Clinical ──────────────────────────────────────────────────────
  clinicalNotes  String?  @db.Text  // Reason for investigation
  clinicalHistory String? @db.Text

  // ── Status Workflow ───────────────────────────────────────────────
  status         String   @default("ORDERED")
  // ORDERED → ACCEPTED → IN_PROGRESS → AWAITING_INTERPRETATION → REPORTED
  // CANCELLED at any point

  // ── Critical Findings ─────────────────────────────────────────────
  isCritical     Boolean  @default(false)
  criticalNote   String?  @db.Text

  // ── Imaging Data ──────────────────────────────────────────────────
  imageCount     Int      @default(0)
  dicomStudyUid  String?  // Placeholder for DICOM integration

  // ── Report ────────────────────────────────────────────────────────
  findings       String?  @db.Text
  impression     String?  @db.Text
  conclusion     String?  @db.Text
  radiologistNotes String? @db.Text
  reportedById   Int?
  reportedAt     DateTime?

  // ── Measurements & Annotations (JSON) ─────────────────────────────
  measurements   String?  @db.Text  // JSON — {"label":"Liver size","value":"15.2","unit":"cm"}
  annotations    String?  @db.Text  // JSON — free-form annotation data

  // ── Machine Integration ───────────────────────────────────────────
  machineResults String?  @db.Text  // Raw machine output / DICOM structured report
  machineModel   String?  // Name/model of the device used

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  Patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)
  Visit   Visit?  @relation(fields: [visitId], references: [id])
  Staff   Staff?  @relation(fields: [requestedById], references: [id])
}

model DentalRecord {
  id             Int      @id @default(autoincrement())
  patientId      Int
  visitId        Int?
  chiefComplaint String?  @db.Text
  diagnosis      String?  @db.Text
  treatment      String?  @db.Text
  notes          String?  @db.Text
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  Patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)
  Visit   Visit?  @relation(fields: [visitId], references: [id])
}

model Appointment {
  id              Int               @id @default(autoincrement())
  patientId       Int
  staffId         Int
  appointmentDate DateTime
  status          AppointmentStatus @default(PENDING)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  Patient         Patient           @relation(fields: [patientId], references: [id], onDelete: Cascade)
  Staff           Staff             @relation(fields: [staffId], references: [id])
}

model LabRequest {
  id                  Int       @id @default(autoincrement())
  patientId           Int
  visitId             Int?
  requestedById       Int

  // ── Request Details ───────────────────────────────────────────────────
  testName            String
  testPanel           String?
  priority            String    @default("ROUTINE")
  referralSource      String?
  referralNotes       String?   @db.Text
  clinicalNotes       String?   @db.Text

  // ── Specimen Tracking ─────────────────────────────────────────────────
  specimenType        String?
  specimenId          String?   @unique
  specimenCollectedAt DateTime?
  collectedByName     String?
  specimenRejected    Boolean   @default(false)
  rejectedAt          DateTime?
  rejectedBy          String?
  rejectionReason     String?   @db.Text
  rejectionCategory   String?   // HEMOLYZED | CLOTTED | INSUFFICIENT | WRONG_CONTAINER | MISLABELED | CONTAMINATED | EXPIRED | TRANSPORT | PREPARATION | DUPLICATE | OTHER

  // ── Processing & TAT ─────────────────────────────────────────────────
  processingStartedAt DateTime?
  processingStartedBy String?

  // ── Results Entry ─────────────────────────────────────────────────────
  results             String?   @db.Text  // JSON array
  resultEnteredAt     DateTime?
  enteredByName       String?

  // ── Validation ────────────────────────────────────────────────────────
  validatedByName     String?
  validatedAt         DateTime?
  isCritical          Boolean   @default(false)
  criticalNote        String?   @db.Text

  // ── Analyzer Integration ──────────────────────────────────────────────
  analyzerType        String?   // CBC | CHEMISTRY | HEMATOLOGY | URINALYSIS | COAGULATION | IMMUNOLOGY | MICROBIOLOGY | OTHER
  analyzerResults     String?   @db.Text  // Raw JSON from analyzer
  analyzerModel       String?
  analyzerImportedAt  DateTime?
  analyzerImportStatus String?  // PENDING | IMPORTED | REVIEWED | REJECTED

  // ── Chain of Custody ─────────────────────────────────────────────────
  chainOfCustody      String?   @db.Text  // JSON array: [{action,by,at,from,to}]

  // ── Attachments ───────────────────────────────────────────────────────
  attachments         String?   @db.Text  // JSON array

  // ── Status ────────────────────────────────────────────────────────────
  status              LabStatus @default(PENDING)

  // ── Meta ──────────────────────────────────────────────────────────────
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  Patient             Patient   @relation(fields: [patientId], references: [id], onDelete: Cascade)
  Visit               Visit?    @relation(fields: [visitId], references: [id])
  Staff               Staff     @relation(fields: [requestedById], references: [id])

  CriticalNotifications CriticalNotification[]
  LabCommunications     LabCommunication[]
  ResultShares          ResultShare[]
}

model CriticalNotification {
  id              Int      @id @default(autoincrement())
  labRequestId    Int
  patientId       Int
  notifiedPerson  String   // Who was notified
  notifiedDept    String   // Department notified
  notificationMethod String // PHONE | PAGE | IN_PERSON | EMAIL | SYSTEM
  notifiedAt      DateTime
  acknowledgedAt  DateTime?
  acknowledgedBy  String?
  notes           String?  @db.Text
  createdAt       DateTime @default(now())

  LabRequest LabRequest @relation(fields: [labRequestId], references: [id], onDelete: Cascade)
  Patient    Patient    @relation(fields: [patientId], references: [id], onDelete: Cascade)
}

model LabCommunication {
  id              Int      @id @default(autoincrement())
  labRequestId    Int?
  patientId       Int?
  messageType     String   // COMMENT | CLARIFICATION | SPECIMEN_ISSUE | REPEAT_REQUEST | CRITICAL_ALERT | GENERAL
  message         String   @db.Text
  senderId        Int
  senderName      String
  senderDept      String
  recipientId     Int?     // Staff ID
  recipientDept   String?  // Department to receive
  isRead          Boolean  @default(false)
  readAt          DateTime?
  parentId        Int?     // For threading
  createdAt       DateTime @default(now())

  LabRequest LabRequest? @relation(fields: [labRequestId], references: [id])
  Patient    Patient?    @relation(fields: [patientId], references: [id])
  Staff      Staff       @relation(fields: [senderId], references: [id])
}

model Notification {
  id          Int      @id @default(autoincrement())
  userId      Int?
  department  String?  // Target department
  title       String
  message     String   @db.Text
  type        String   // CRITICAL_RESULT | RESULT_READY | RESULT_SHARED | COMMUNICATION | REPEAT_REQUEST | GENERAL
  referenceId Int?     // Optional: ID of related entity (lab request, etc.)
  referenceType String? // lab_request | communication | etc.
  isRead      Boolean  @default(false)
  readAt      DateTime?
  createdAt   DateTime @default(now())
}

model ResultShare {
  id            Int      @id @default(autoincrement())
  labRequestId  Int
  patientId     Int
  sharedById    Int
  sharedByName  String
  targetUserId  Int?     // Specific user
  targetDept    String   // Target department
  includeReport Boolean  @default(true)
  note          String?  @db.Text
  sharedAt      DateTime @default(now())
  viewedAt      DateTime?

  LabRequest LabRequest @relation(fields: [labRequestId], references: [id], onDelete: Cascade)
  Patient    Patient    @relation(fields: [patientId], references: [id], onDelete: Cascade)
  Staff      Staff?     @relation(fields: [sharedById], references: [id])
}

model Prescription {
  id           Int      @id @default(autoincrement())
  patientId    Int
  visitId      Int?
  medication   String
  dosage       String
  instructions String   @db.Text
  status       PrescriptionStatus @default(PENDING)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  Patient      Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  Visit        Visit?   @relation(fields: [visitId], references: [id])
}

model Billing {
  id          Int           @id @default(autoincrement())
  patientId   Int
  visitId     Int? // Essential for calculating line-items per visit
  amount      Float
  description String?       @db.Text
  status      BillingStatus @default(UNPAID)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  Patient     Patient       @relation(fields: [patientId], references: [id], onDelete: Cascade)
  Visit       Visit?        @relation(fields: [visitId], references: [id])
}

model Staff {
  id             Int           @id @default(autoincrement())
  fullName       String
  phoneNumber    String?
  department     String
  specialization String?
  userId         Int           @unique
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  Appointment    Appointment[]
  LabRequest     LabRequest[]
  ImagingRequest ImagingRequest[]
  LabCommunications LabCommunication[]
  ResultShares     ResultShare[]
  User             User          @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AuditLog {
  id        Int      @id @default(autoincrement())
  action    String
  details   String?  @db.Text
  userId    Int
  createdAt DateTime @default(now())
  User      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// --- ENUMS ---

enum PatientStatus {
  AWAITING_TRIAGE
  AWAITING_DOCTOR
  AWAITING_DENTIST
  AWAITING_SONOGRAPHY
  AWAITING_RADIOLOGY
  AWAITING_LAB
  IN_CONSULTATION
  AWAITING_PHARMACY
  AWAITING_CASHIER
  DISCHARGED
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELLED
}

enum BillingStatus {
  UNPAID
  PAID
  PARTIAL
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum LabStatus {
  PENDING
  SPECIMEN_COLLECTED
  PROCESSING
  AWAITING_VALIDATION
  COMPLETED
  REJECTED
}
enum PrescriptionStatus {
  PENDING
  DISPENSED
}
enum Role {
  ADMINISTRATOR
  DENTIST
  DOCTOR
  NURSE
  NURSE_MIDWIFE
  MIDWIFE
  LAB_TECHNICIAN
  SONOGRAPHER
  RADIOLOGIST
  RADIOLOGIST_SONOGRAPHER
  RECEPTIONIST
  CASHIER
  PHARMACIST
}
